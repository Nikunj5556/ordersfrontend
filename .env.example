# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Razorpay ──────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── WhatsApp OTP (replace with your provider) ─────────────────
# Option A: Gupshup / AiSensy / Interakt
WHATSAPP_API_URL=https://api.your-whatsapp-provider.com/send
WHATSAPP_API_TOKEN=your_whatsapp_bearer_token

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://breakfastclub.co.in
NODE_ENV=production
